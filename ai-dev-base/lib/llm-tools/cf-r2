#!/bin/bash
# cf-r2 — Cloudflare R2 object storage operations via S3-compatible API
#
# Usage:
#   cf-r2 ls [PREFIX] [--limit N]       List objects (optional prefix filter and max results)
#   cf-r2 get KEY                      Download object to stdout
#   cf-r2 put KEY [--file PATH]        Upload from stdin or file
#   cf-r2 head KEY                     Get object metadata
#   cf-r2 rm KEY                       Delete an object
#   cf-r2 buckets                      List buckets
#
# Output: JSON (ls, head, buckets) or raw content (get)
# Requires: R2_ENDPOINT_URL, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME
#
# Examples:
#   cf-r2 ls raw/scryfall/
#   cf-r2 get raw/scryfall/2024-01-15/cards.json | jq '.[:3]'
#   echo '{"test":1}' | cf-r2 put test/hello.json
#   cf-r2 head raw/scryfall/2024-01-15/cards.json

set -euo pipefail

usage() {
    sed -n '2,/^[^#]/{ /^#/s/^# \?//p }' "$0"
    exit "${1:-0}"
}

[ $# -lt 1 ] && usage 0

# Validate env
for var in R2_ENDPOINT_URL R2_ACCESS_KEY_ID R2_SECRET_ACCESS_KEY R2_BUCKET_NAME; do
    if [ -z "${!var:-}" ]; then
        echo "{\"error\": \"${var} not set. Run doppler login or check .env\"}" >&2
        exit 1
    fi
done

BUCKET="$R2_BUCKET_NAME"
ENDPOINT="$R2_ENDPOINT_URL"

# S3-compatible request via Python (handles AWS Signature V4 signing)
_s3_request() {
    local method="$1" path="$2" body_file="${3:-}" query="${4:-}"
    python3 -c "
import sys, hashlib, hmac, datetime, urllib.request, urllib.error, ssl

method, path, body_file, query = '$method', '$path', '$body_file', '$query'
endpoint = '$ENDPOINT'
bucket = '$BUCKET'
access_key = '$R2_ACCESS_KEY_ID'
secret_key = '$R2_SECRET_ACCESS_KEY'

host = endpoint.replace('https://','').replace('http://','').rstrip('/')
region, service = 'auto', 's3'
now = datetime.datetime.utcnow()
date_stamp = now.strftime('%Y%m%d')
amz_date = now.strftime('%Y%m%dT%H%M%SZ')

body = b''
if body_file and body_file != '':
    with open(body_file, 'rb') as f: body = f.read()

content_hash = hashlib.sha256(body).hexdigest()
canonical_uri = f'/{bucket}{path}'

# S3 Sig V4 requires query params sorted alphabetically
import urllib.parse
sorted_query = '&'.join(sorted(query.split('&'))) if query else ''

canonical_headers = f'host:{host}\nx-amz-content-sha256:{content_hash}\nx-amz-date:{amz_date}\n'
signed_headers = 'host;x-amz-content-sha256;x-amz-date'
canonical_request = f'{method}\n{canonical_uri}\n{sorted_query}\n{canonical_headers}\n{signed_headers}\n{content_hash}'

scope = f'{date_stamp}/{region}/{service}/aws4_request'
string_to_sign = f'AWS4-HMAC-SHA256\n{amz_date}\n{scope}\n{hashlib.sha256(canonical_request.encode()).hexdigest()}'

def sign(key, msg): return hmac.new(key, msg.encode(), hashlib.sha256).digest()
k = sign(sign(sign(sign(f'AWS4{secret_key}'.encode(), date_stamp), region), service), 'aws4_request')
signature = hmac.new(k, string_to_sign.encode(), hashlib.sha256).hexdigest()

auth = f'AWS4-HMAC-SHA256 Credential={access_key}/{scope}, SignedHeaders={signed_headers}, Signature={signature}'
url = f'{endpoint}/{bucket}{path}'
if sorted_query: url += f'?{sorted_query}'

req = urllib.request.Request(url, data=body if method == 'PUT' else None, method=method)
req.add_header('Authorization', auth)
req.add_header('x-amz-content-sha256', content_hash)
req.add_header('x-amz-date', amz_date)

ctx = ssl.create_default_context()
try:
    with urllib.request.urlopen(req, context=ctx) as resp:
        sys.stdout.buffer.write(resp.read())
except urllib.error.HTTPError as e:
    sys.stderr.write(e.read().decode()); sys.exit(1)
" 2>&1
}

# Convert S3 XML list response to JSON
_xml_list_to_json() {
    python3 -c "
import sys, xml.etree.ElementTree as ET, json
root = ET.fromstring(sys.stdin.read())
ns = root.tag.split('}')[0] + '}' if '}' in root.tag else ''
objects = []
for c in root.findall(f'{ns}Contents'):
    obj = {}
    for field in ['Key', 'Size', 'LastModified', 'ETag']:
        el = c.find(f'{ns}{field}')
        if el is not None:
            obj[field.lower()] = el.text
    objects.append(obj)
print(json.dumps(objects, indent=2))
" 2>/dev/null || echo '{"error": "Failed to parse XML response"}'
}

ACTION="$1"
shift

case "$ACTION" in
    ls)
        PREFIX=""
        MAX_KEYS=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --limit) MAX_KEYS="$2"; shift 2 ;;
                -*) echo "{\"error\": \"Unknown flag: $1\"}" >&2; exit 1 ;;
                *) PREFIX="$1"; shift ;;
            esac
        done
        QUERY=""
        [ -n "$PREFIX" ] && QUERY="prefix=${PREFIX}&"
        [ -n "$MAX_KEYS" ] && QUERY="${QUERY}max-keys=${MAX_KEYS}&"
        QUERY="${QUERY}list-type=2"
        _s3_request GET "/" "" "$QUERY" | _xml_list_to_json
        ;;

    get)
        [ $# -lt 1 ] && { echo '{"error": "Usage: cf-r2 get KEY"}' >&2; exit 1; }
        _s3_request GET "/$1"
        ;;

    put)
        [ $# -lt 1 ] && { echo '{"error": "Usage: cf-r2 put KEY [--file PATH]"}' >&2; exit 1; }
        KEY="$1"; shift
        FILE=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --file) FILE="$2"; shift 2 ;;
                *) echo "{\"error\": \"Unknown arg: $1\"}" >&2; exit 1 ;;
            esac
        done
        if [ -n "$FILE" ]; then
            _s3_request PUT "/$KEY" "$FILE"
        else
            TMP=$(mktemp)
            cat > "$TMP"
            _s3_request PUT "/$KEY" "$TMP"
            rm -f "$TMP"
        fi
        echo '{"status": "ok"}'
        ;;

    head)
        [ $# -lt 1 ] && { echo '{"error": "Usage: cf-r2 head KEY"}' >&2; exit 1; }
        KEY="$1"
        # HEAD requests: use curl directly to capture headers as JSON
        python3 -c "
import sys, hashlib, hmac, datetime, urllib.request, urllib.error, ssl, json

endpoint = '$ENDPOINT'
bucket = '$BUCKET'
access_key = '$R2_ACCESS_KEY_ID'
secret_key = '$R2_SECRET_ACCESS_KEY'
key = '$KEY'

host = endpoint.replace('https://','').replace('http://','').rstrip('/')
region, service = 'auto', 's3'
now = datetime.datetime.utcnow()
date_stamp = now.strftime('%Y%m%d')
amz_date = now.strftime('%Y%m%dT%H%M%SZ')

content_hash = hashlib.sha256(b'').hexdigest()
canonical_uri = f'/{bucket}/{key}'
canonical_headers = f'host:{host}\nx-amz-content-sha256:{content_hash}\nx-amz-date:{amz_date}\n'
signed_headers = 'host;x-amz-content-sha256;x-amz-date'
canonical_request = f'HEAD\n{canonical_uri}\n\n{canonical_headers}\n{signed_headers}\n{content_hash}'

scope = f'{date_stamp}/{region}/{service}/aws4_request'
string_to_sign = f'AWS4-HMAC-SHA256\n{amz_date}\n{scope}\n{hashlib.sha256(canonical_request.encode()).hexdigest()}'

def sign(k, msg): return hmac.new(k, msg.encode(), hashlib.sha256).digest()
k = sign(sign(sign(sign(f'AWS4{secret_key}'.encode(), date_stamp), region), service), 'aws4_request')
signature = hmac.new(k, string_to_sign.encode(), hashlib.sha256).hexdigest()

auth = f'AWS4-HMAC-SHA256 Credential={access_key}/{scope}, SignedHeaders={signed_headers}, Signature={signature}'
url = f'{endpoint}/{bucket}/{key}'

req = urllib.request.Request(url, method='HEAD')
req.add_header('Authorization', auth)
req.add_header('x-amz-content-sha256', content_hash)
req.add_header('x-amz-date', amz_date)

ctx = ssl.create_default_context()
try:
    with urllib.request.urlopen(req, context=ctx) as resp:
        headers = dict(resp.headers)
        meta = {
            'key': key,
            'size': headers.get('Content-Length'),
            'content_type': headers.get('Content-Type'),
            'last_modified': headers.get('Last-Modified'),
            'etag': headers.get('ETag'),
        }
        print(json.dumps(meta, indent=2))
except urllib.error.HTTPError as e:
    if e.code == 404:
        print(json.dumps({'error': 'Not found', 'key': key}), file=sys.stderr)
    else:
        print(json.dumps({'error': f'HTTP {e.code}', 'key': key}), file=sys.stderr)
    sys.exit(1)
"
        ;;

    rm)
        [ $# -lt 1 ] && { echo '{"error": "Usage: cf-r2 rm KEY"}' >&2; exit 1; }
        _s3_request DELETE "/$1"
        echo '{"status": "deleted"}'
        ;;

    buckets)
        # List buckets hits the endpoint root without a bucket path
        curl -s "${ENDPOINT}/" \
            -H "Authorization: AWS4-HMAC-SHA256 ..." 2>/dev/null || \
            echo '{"info": "Bucket listing requires account-level auth. Current bucket: '"${BUCKET}"'"}'
        ;;

    -h|--help) usage 0 ;;
    *) echo "{\"error\": \"Unknown action: ${ACTION}. Use: ls, get, put, head, rm, buckets\"}" >&2; exit 1 ;;
esac
